<style is:global>

  .animate-parpadeo {
    animation: parpadeoSuave 2s infinite ease-in-out;
  }

  @keyframes parpadeoSuave {
    0%, 100% {
      opacity: 0.3;
      transform: translateY(0);
    }
    50% {
      opacity: 1;
      transform: translateY(6px); 
    }
  }
  #logo-mask {
    background: white; 
    mask-image: url("/gloglo.png");
    mask-position: center 25%;
    mask-repeat: no-repeat;
    mask-size: clamp(5000vh, 3500%, 0vh);
    filter: drop-shadow(0 0 20px rgba(255,255,255,0.1));
  }

  .moneda-oro {
    position: absolute;
    width: 25px;
    height: 25px;
    background: radial-gradient(circle at 35% 35%, #ffe680, #f59e0b 55%, #b45309);
    border-radius: 50%;
    box-shadow: 0 5px 12px rgba(0, 0, 0, 0.7), inset 0 -2px 4px rgba(0, 0, 0, 0.4), inset 0 2px 4px rgba(255, 255, 255, 0.6);
    top: -40px;
  }
</style>

<script>
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.registerPlugin(ScrollTrigger)

  // --- LLUVIA DE MONEDAS ---
  const contenedorMonedas = document.getElementById("lluvia-monedas");
  const cantidadMonedas = 45; 
  

  if (contenedorMonedas) {
    for (let i = 0; i < cantidadMonedas; i++) {
      const moneda = document.createElement("div");
      moneda.classList.add("moneda-oro");
      gsap.set(moneda, {
        left: `${Math.random() * 100}%`,
        scale: Math.random() * 0.6 + 0.5,
        opacity: 0
      });
      contenedorMonedas.appendChild(moneda);
    }
  }
  const todasLasMonedas = document.querySelectorAll(".moneda-oro");

  // --- CONFIGURACIÓN DEL VIDEO ---
  const video = document.getElementById("video-scroll") as HTMLVideoElement;
  let videoContenedor = { currentTime: 0 };

  // --- TIMELINE COMPLETAMENTE RE-ESTRUCTURADO ---
  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: "body",
      start: "top top",
      end: "bottom bottom",
      scrub: 4.5, 
    },
  })




tl.to("#LogoVI", { opacity: 1, display: "none", duration: 2.0 }, 2.0);
  tl.to("#hero-key", { duration: 6.0, scale: 1 }, 0)
    .to("#hero-key-logo", { opacity: 0, duration: 4.0 }, 0) 
    .to("#hero-footer", { opacity: 0, duration: 4.0 }, 0)
    
  tl.to("#logo-mask", { maskSize: "clamp(22vh, 25%, 28vh)", duration: 6.0, ease: "expo.out" }, 6.0)
    .to("#hero-key", { opacity: 0, duration: 2.0 }, 9.0)
    
// ==========================================
  // FASE 2: JUEGA A GANAR + MONEDAS (14.0 a 28.0)
  // ==========================================
  tl.to("#texto-bajo-gloglo", { opacity: 1, y: 0, duration: 4.0, ease: "back.out(1.0)" }, 14.0)
  

  todasLasMonedas.forEach((moneda) => {
    tl.to(moneda, {
      opacity: 1,
      y: window.innerHeight + 100,
      rotationX: Math.random() * 720 + 360,
      rotationY: Math.random() * 720 + 360,
      rotationZ: Math.random() * 360,
      duration: Math.random() * 6.0 + 5.0, 
      ease: "power1.inOut"
    }, 14.0);
  });
  
  tl.to(".moneda-oro", { opacity: 0, duration: 2.0 }, 24.0)
    .to("#texto-bajo-gloglo", { opacity: 0, scale: 0.8, duration: 3.0 }, 25.0)
  
  // Transmisión expansiva: Forzamos la desaparición total del logo del tío Gloglo
  tl.to("#logo-mask", { maskSize: "clamp(6000vh, 4500%, 0vh)", duration: 6.0, ease: "power4.in" }, 28.0) 
  
  tl.to("#logo-mask", { opacity: 0, display: "none", duration: 1.0 }, 32.5)

  // ==========================================
  // FASE 3: SEGUNDA SECCIÓN - DATOS (34.0 a 54.0)
  // ==========================================
  tl.to("#segunda-seccion", { opacity: 1, pointerEvents: "auto", duration: 3.0 }, 33.0) 
  tl.to("#segunda-seccion-texto", { opacity: 1, y: 0, duration: 5.0, ease: "power2.out" }, 34.0)

  // ==========================================
  // FASE 4: TERCERA SECCIÓN - TARJETAS Y BRILLO (54.0 a 76.0)
  // ==========================================
  tl.to("#tercer-seccion", { opacity: 1, pointerEvents: "auto", duration: 3.0 }, 54.0)
    .to("#tercer-seccion-titulo", { opacity: 1, y: 0, duration: 3.0 }, 56.0)
    
    .to("#tercer-seccion-titulo", { bgPosition: "200% center", duration: 12.0, ease: "none" }, 56.0)

    .to(".tarjeta-unica", { opacity: 1, y: 0, stagger: 1.2, duration: 4.0, ease: "back.out(1.0)" }, 58.0)
    .to("#tercer-seccion-subtexto", { opacity: 1, duration: 2.0 }, 64.0)
    .to("#btn-telegram", { opacity: 1, scale: 1, duration: 3.0, ease: "elastic.out(1, 0.75)" }, 65.0)

  tl.to("#tercer-seccion", { opacity: 1, y: -60, duration: 4.0 }, 76.0)

  // ==========================================
  // FASE 5: VIDEO SCROLL (80.0 a 100.0)
  // ==========================================
  tl.to("#cuarta-seccion-video", { opacity: 1, pointerEvents: "auto", duration: 3.0 }, 80.0)

  if (video) {
    const syncVideo = () => {
      tl.to(videoContenedor, {
        currentTime: video.duration || 5,
        duration: 18.0, 
        ease: "none",
        onUpdate: () => {
          video.currentTime = videoContenedor.currentTime;
        }
      }, 81.0);
    };
    video.addEventListener("loadedmetadata", syncVideo);
    if(video.duration) syncVideo();
  }

  // ==========================================
  // FASE 6: VOCES DE LA COMUNIDAD (90.0 a 112.0)
  // ==========================================
  tl.to("#video-overlay", { backgroundColor: "rgba(0, 0, 0, 0.7)", duration: 4.0 }, 86.0)
    .to("#quinta-seccion-comunidad", { opacity: 1, pointerEvents: "auto", duration: 3.0 }, 90.0)
    .to("#voces-titulo", { opacity: 1, y: 0, filter: "blur(0px)", duration: 4.0, ease: "power3.out" }, 92.0)
    .to("#voces-subtitulo", { opacity: 1, y: 0, duration: 3.0 }, 95.0)
    .to("#voces-grid", { opacity: 1, y: 0, duration: 5.0, ease: "power2.out" }, 97.0)

  tl.to("#quinta-seccion-comunidad", { opacity: 0, y: -40, duration: 4.0 }, 112.0)
    .to("#cuarta-seccion-video", { opacity: 1, duration: 4.0 }, "<")

  // ==========================================
  // FASE 7: SOBRE GLOGLOKING (116.0 a 138.0)
  // ==========================================
  tl.to("#seccion-sobre-gloglo", { opacity: 1, pointerEvents: "auto", duration: 4.0 }, 116.0)
    .to("#sobre-gloglo-contenido", { opacity: 1, y: 0, duration: 5.0, ease: "power2.out" }, 119.0)

  tl.to("#sobre-gloglo-contenido", { opacity: 0, y: -50, duration: 4.0, ease: "power2.in" }, 138.0)
    .to("#seccion-sobre-gloglo", { opacity: 0, duration: 3.0 }, 141.0)

  // ==========================================
  // FASE 8: DESEMBARCO FINAL JUNTOS (144.0+)
  // ==========================================
  tl.to("#seccion-resultados-final", { opacity: 1, pointerEvents: "auto", duration: 5.0 }, 144.0)
// ==========================================
  // FASE 1: HERO & LOGO MASK (0.0 a 12.0)
  // ==========================================
  
  // 1. ANIMACIÓN INICIAL EN LOOP (Parpadea solo al inicio si el scroll está arriba)
  const footerTween = gsap.fromTo("#hero-footer", 
    { opacity: 0.3, y: 0 }, 
    { opacity: 1, y: 8, duration: 1.2, repeat: -1, yoyo: true, ease: "power1.inOut" }
  );

  // 2. CONTROL DEL FOOTER DENTRO DEL TIMELINE GLOBAL DEL SCROLL
  tl.to("#hero-key", { duration: 6.0, scale: 1 }, 0)
    .to("#hero-key-logo", { opacity: 0, duration: 4.0 }, 0) 
    
    // En cuanto el usuario baja un milímetro (de 0.0 a 2.0 en el scroll), matamos el footer
    .to("#hero-footer", { 
      opacity: 0, 
      pointerEvents: "none", 
      duration: 2.0,
      onStart: () => {
        // Pausamos el bucle interno para liberar memoria del navegador
        footerTween.pause();
      },
      onReverseComplete: () => {
        // Si el usuario regresa arriba del todo, el parpadeo vuelve a marchar
        footerTween.play();
      }
    }, 0)
    
  tl.to("#logo-mask", { maskSize: "clamp(22vh, 25%, 28vh)", duration: 6.0, ease: "expo.out" }, 6.0)
    .to("#hero-key", { opacity: 0, duration: 2.0 }, 9.0)

  // --- CONTROL DEL MENÚ DESPLEGABLE Y NAVEGACIÓN POR LABELS ---
  const btnOpenMenu = document.getElementById("btn-open-menu");
  const btnCloseMenu = document.getElementById("btn-close-menu");
  const menuOverlay = document.getElementById("menu-overlay");
  const linkSobreMi = document.getElementById("link-sobre-mi");

  function abrirMenu() {
    if (menuOverlay) {
      menuOverlay.classList.remove("invisible");
      gsap.to(menuOverlay, { opacity: 1, duration: 0.4, ease: "power2.out" });
      gsap.to("#link-sobre-mi", { y: 0, delay: 0.2, duration: 0.4, ease: "back.out(1.5)" });
    }
  }

  function cerrarMenu() {
    if (menuOverlay) {
      gsap.to(menuOverlay, { 
        opacity: 0, 
        duration: 0.3, 
        ease: "power2.in",
        onComplete: () => {
          menuOverlay.classList.add("invisible");
          gsap.set("#link-sobre-mi", { y: 16 });
        }
      });
    }
  }

  // Event Listeners para abrir y cerrar el menú
  btnOpenMenu?.addEventListener("click", abrirMenu);
  btnCloseMenu?.addEventListener("click", cerrarMenu);

  // Solución para la navegación: Calcular el progreso exacto del timeline en vez de saltar al div fixed
  linkSobreMi?.addEventListener("click", (e) => {
    e.preventDefault();
    cerrarMenu();

    // Calculamos en qué porcentaje del scroll general inicia la Fase 7 (Sobre Gloglo)
    const totalDuration = tl.totalDuration();
    const targetTime = 119.0; 
    const scrollProgress = targetTime / totalDuration;

    // Calculamos los píxeles de scroll basándonos en la altura total real del documento
    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
    
    // Hacemos scroll fluido al punto exacto de la animación
    window.scrollTo({
      top: maxScroll * scrollProgress,
      behavior: "smooth"
    });
  });
</script>